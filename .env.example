# Samuhik Netlify demo environment

# Frontend Supabase access. Use the existing project URL and anon key.
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Demo mode keeps the app on in-memory sample data for sales walkthroughs.
# Set to false only when the existing Supabase project has the expected data.
VITE_DEMO_MODE=true

# Phase 4: Netlify serverless function only. Never expose this as VITE_*.
GEMINI_API_KEY=your-gemini-api-key

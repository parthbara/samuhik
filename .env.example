# ── Backend (Node / Fastify) ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Supabase — Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service role key (never expose to browser)

# LM Studio CORS bridge (run: npm run llm:bridge)
# The backend calls this internally — no browser exposure needed.
LM_STUDIO_BASE_URL=http://127.0.0.1:8787    # bridge port
LM_STUDIO_MODEL=gemma-4-e4b-uncensored-hauhaucs-aggressive
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=2

# Evolution API — default (can be overridden per tenant in DB)
EVOLUTION_API_URL=https://evo.yourdomain.com
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=samuhik-instance
EVOLUTION_WEBHOOK_SECRET=   # optional HMAC secret for webhook verification

# ── Frontend (Vite — prefix with VITE_ to expose to browser) ──────────────────
# API key for the frontend to authenticate with the Fastify backend.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then SHA-256 hash it and store the hash in the tenants.api_key_hash column.
VITE_API_KEY=your-raw-frontend-api-key
